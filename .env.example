# ========================
# NEXUS BANK - Docker Environment Variables
# ========================
# Copy this file to .env and update the values

# Database Configuration
POSTGRES_DB=nexus_bank
POSTGRES_USER=nexus_user
POSTGRES_PASSWORD=your_secure_password_here

# Django Configuration
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production-make-it-long-and-random

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# CORS Configuration (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,https://your-domain.com

# Frontend API URL
VITE_API_URL=http://localhost:8000/api
